<Window x:Class="FloorballCoach.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FloorballCoach"
        xmlns:views="clr-namespace:FloorballCoach.Views"
        xmlns:vm="clr-namespace:FloorballCoach.ViewModels"
        xmlns:helpers="clr-namespace:FloorballCoach.Helpers"
        mc:Ignorable="d"
        Title="Floorball Coach" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Converters -->
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <!-- DataTemplates for ViewModels -->
        <DataTemplate DataType="{x:Type vm:TeamManagementViewModel}">
            <views:TeamManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlayerDatabaseViewModel}">
            <views:PlayerDatabaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RosterViewModel}">
            <views:RosterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LineupViewModel}">
            <views:LineupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupViewModel}">
            <views:BackupView/>
        </DataTemplate>

        <!-- Button Style -->
        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <Border Grid.Row="0" Background="#1565C0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Floorball Coach" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"
                          Margin="10,0,30,0"/>
                
                <Button Content="Lag" 
                        Style="{StaticResource NavigationButtonStyle}"
                        Command="{Binding ShowTeamManagementCommand}"/>
                
                <Button Content="Spelardatabas" 
                        Style="{StaticResource NavigationButtonStyle}"
                        Command="{Binding ShowPlayerDatabaseCommand}"/>
                
                <Button Content="Trupp" 
                        Style="{StaticResource NavigationButtonStyle}"
                        Command="{Binding ShowRosterCommand}"/>
                
                <Button Content="Uppställning" 
                        Style="{StaticResource NavigationButtonStyle}"
                        Command="{Binding ShowLineupCommand}"/>
                
                <Button Content="Backup" 
                        Style="{StaticResource NavigationButtonStyle}"
                        Command="{Binding ShowBackupCommand}"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" 
                       Content="{Binding CurrentViewModel}"
                       Margin="10"/>
    </Grid>
</Window>
