<Window x:Class="FloorballCoach.Views.AddEditPlayerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FloorballCoach.Views"
        xmlns:models="clr-namespace:FloorballCoach.Models"
        mc:Ignorable="d"
        Title="Add/Edit Player" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,3"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Player Information" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- First Name -->
                <TextBlock Text="First Name *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="FirstNameTextBox" Style="{StaticResource TextBoxStyle}"/>

                <!-- Last Name -->
                <TextBlock Text="Last Name *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="LastNameTextBox" Style="{StaticResource TextBoxStyle}"/>

                <!-- Jersey Number -->
                <TextBlock Text="Jersey Number *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="JerseyNumberTextBox" Style="{StaticResource TextBoxStyle}"/>

                <!-- Position -->
                <TextBlock Text="Position *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="PositionComboBox" 
                          Padding="8"
                          FontSize="14"
                          Margin="0,0,0,10">
                    <ComboBoxItem Content="Goalkeeper" Tag="Goalkeeper"/>
                    <ComboBoxItem Content="Center" Tag="Center"/>
                    <ComboBoxItem Content="Forward" Tag="Forward"/>
                    <ComboBoxItem Content="Defender" Tag="Defender"/>
                </ComboBox>

                <!-- Date of Birth -->
                <TextBlock Text="Date of Birth *" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="DateOfBirthPicker" 
                           Padding="8"
                           FontSize="14"
                           Margin="0,0,0,10"/>

                <!-- Statistics Section -->
                <TextBlock Text="Statistics" 
                          FontSize="18" 
                          FontWeight="Bold"
                          Margin="0,15,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Games Played -->
                        <TextBlock Text="Games Played" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="GamesPlayedTextBox" Text="0" Style="{StaticResource TextBoxStyle}"/>

                        <!-- Goals -->
                        <TextBlock Text="Goals" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="GoalsTextBox" Text="0" Style="{StaticResource TextBoxStyle}"/>

                        <!-- Assists -->
                        <TextBlock Text="Assists" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="AssistsTextBox" Text="0" Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <!-- Penalties -->
                        <TextBlock Text="Penalties" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="PenaltiesTextBox" Text="0" Style="{StaticResource TextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <TextBlock Text="Notes" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NotesTextBox" 
                        Style="{StaticResource TextBoxStyle}"
                        Height="80"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"/>

                <!-- Active Status -->
                <CheckBox x:Name="IsActiveCheckBox" 
                         Content="Active Player" 
                         IsChecked="True"
                         FontWeight="SemiBold"
                         Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" 
                Background="White" 
                Padding="10" 
                Margin="-20,20,-20,-20"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" 
                        x:Name="SaveButton"
                        Click="SaveButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"/>
                <Button Content="Cancel" 
                        x:Name="CancelButton"
                        Click="CancelButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Background="#F44336"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
