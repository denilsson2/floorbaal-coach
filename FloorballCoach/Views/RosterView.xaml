<UserControl x:Class="FloorballCoach.Views.RosterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FloorballCoach.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1400">

    <UserControl.Resources>
        <Style x:Key="PlayerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - All Players -->
        <Border Grid.Column="0" 
                Background="#F9F9F9" 
                Padding="20"
                CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Available Players"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="1"
                           Text="Click ➕ to add player to roster"
                           FontSize="12"
                           Foreground="#888888"
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AvailablePlayers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlayerCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#1565C0" 
                                                        CornerRadius="3" 
                                                        Padding="5,2"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding JerseyNumber}" 
                                                               Foreground="White" 
                                                               FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Text="{Binding FullName}" 
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Position}" 
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="➕"
                                                    FontSize="16"
                                                    Padding="8,4"
                                                    Background="#4CAF50"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Margin="0,0,5,0"
                                                    Command="{Binding DataContext.AddToRosterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Add to roster"/>
                                            <Button Content="🗑️"
                                                    FontSize="14"
                                                    Padding="8,4"
                                                    Background="#F44336"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.DeletePlayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete player from database"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Panel - Current Roster -->
        <Border Grid.Column="2" 
                Background="White" 
                Padding="20"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Current Roster"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        
                        <Button Content="💾 Save Roster"
                                HorizontalAlignment="Right"
                                Padding="15,8"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#4CAF50"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding SaveRosterCommand}"
                                ToolTip="Save the current roster selection">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#45a049"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    
                    <TextBlock Text="Players organized by position"
                               FontSize="12"
                               Foreground="#888888"
                               Margin="0,0,0,10"/>

                    <!-- Roster Summary -->
                    <Border Background="#F5F5F5"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="15"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Roster Summary"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="Total Players:" FontWeight="SemiBold" Width="120"/>
                                        <TextBlock Text="{Binding RosterPlayers.Count}" FontWeight="Bold" Foreground="#1565C0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="🥅 Goalkeepers:" Width="120"/>
                                        <TextBlock Text="{Binding Goalkeepers.Count}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="🛡️ Defenders:" Width="120"/>
                                        <TextBlock Text="{Binding Defenders.Count}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <TextBlock Text="⭐ Centers:" Width="120"/>
                                        <TextBlock Text="{Binding Centers.Count}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡ Forwards:" Width="120"/>
                                        <TextBlock Text="{Binding Forwards.Count}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Goalkeepers -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🥅 Goalkeepers ({0})">
                                <Binding Path="Goalkeepers.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Goalkeepers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlayerCardStyle}"
                                        Background="#E3F2FD"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RosterPlayerCard_MouseDown"
                                        MouseLeftButtonUp="RosterPlayerCard_MouseUp"
                                        MouseMove="RosterPlayerCard_MouseMove"
                                        AllowDrop="True"
                                        Drop="RosterPlayerCard_Drop"
                                        DragEnter="RosterPlayerCard_DragEnter"
                                        DragLeave="RosterPlayerCard_DragLeave"
                                        ToolTip="Drag to reorder, click to edit">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="#1565C0" 
                                                    CornerRadius="3" 
                                                    Padding="5,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding JerseyNumber}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="❌"
                                                FontSize="12"
                                                Padding="6,2"
                                                Background="#F44336"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveFromRosterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove from roster"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Defenders -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🛡️ Defenders ({0})">
                                <Binding Path="Defenders.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Defenders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlayerCardStyle}"
                                        Background="#FCE4EC"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RosterPlayerCard_MouseDown"
                                        MouseLeftButtonUp="RosterPlayerCard_MouseUp"
                                        MouseMove="RosterPlayerCard_MouseMove"
                                        AllowDrop="True"
                                        Drop="RosterPlayerCard_Drop"
                                        DragEnter="RosterPlayerCard_DragEnter"
                                        DragLeave="RosterPlayerCard_DragLeave"
                                        ToolTip="Drag to reorder, click to edit">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="#1565C0" 
                                                    CornerRadius="3" 
                                                    Padding="5,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding JerseyNumber}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="❌"
                                                FontSize="12"
                                                Padding="6,2"
                                                Background="#F44336"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveFromRosterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove from roster"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Centers -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="⭐ Centers ({0})">
                                <Binding Path="Centers.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Centers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlayerCardStyle}"
                                        Background="#FFF8E1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RosterPlayerCard_MouseDown"
                                        MouseLeftButtonUp="RosterPlayerCard_MouseUp"
                                        MouseMove="RosterPlayerCard_MouseMove"
                                        AllowDrop="True"
                                        Drop="RosterPlayerCard_Drop"
                                        DragEnter="RosterPlayerCard_DragEnter"
                                        DragLeave="RosterPlayerCard_DragLeave"
                                        ToolTip="Drag to reorder, click to edit">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="#1565C0" 
                                                    CornerRadius="3" 
                                                    Padding="5,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding JerseyNumber}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="❌"
                                                FontSize="12"
                                                Padding="6,2"
                                                Background="#F44336"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveFromRosterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove from roster"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Forwards -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="⚡ Forwards ({0})">
                                <Binding Path="Forwards.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding Forwards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PlayerCardStyle}"
                                        Background="#E8F5E9"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RosterPlayerCard_MouseDown"
                                        MouseLeftButtonUp="RosterPlayerCard_MouseUp"
                                        MouseMove="RosterPlayerCard_MouseMove"
                                        AllowDrop="True"
                                        Drop="RosterPlayerCard_Drop"
                                        DragEnter="RosterPlayerCard_DragEnter"
                                        DragLeave="RosterPlayerCard_DragLeave"
                                        ToolTip="Drag to reorder, click to edit">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="#1565C0" 
                                                    CornerRadius="3" 
                                                    Padding="5,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding JerseyNumber}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding FullName}" 
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="❌"
                                                FontSize="12"
                                                Padding="6,2"
                                                Background="#F44336"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveFromRosterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove from roster"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
