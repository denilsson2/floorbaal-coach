<UserControl x:Class="FloorballCoach.Views.PlayerDatabaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FloorballCoach.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <Style x:Key="PlayerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Gray" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Player Database" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>
        
        <TextBlock Grid.Row="0"
                   Text="Click ✏️ on a player card to edit"
                   FontSize="12"
                   Foreground="#888888"
                   Margin="0,35,0,20"
                   HorizontalAlignment="Left"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" 
                Background="#F5F5F5" 
                Padding="10" 
                Margin="0,0,0,10"
                CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <TextBox Grid.Column="0" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Padding="8"
                         FontSize="14"
                         MaxWidth="400"
                         HorizontalAlignment="Left">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search players..." 
                                                             Foreground="Gray" 
                                                             Margin="5,0,0,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Add Player" 
                            Command="{Binding AddPlayerCommand}"
                            Style="{StaticResource ButtonStyle}"/>
                    <Button Content="Edit Player" 
                            Command="{Binding EditPlayerCommand}"
                            Style="{StaticResource ButtonStyle}"
                            Background="#2196F3"/>
                    <Button Content="Delete Player" 
                            Command="{Binding DeletePlayerCommand}"
                            Style="{StaticResource ButtonStyle}"
                            Background="#F44336"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Player List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Players}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PlayerCardStyle}" 
                                Width="250" 
                                Height="180"
                                MouseLeftButtonDown="PlayerCard_Click">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Jersey Number & Name -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="#1565C0" 
                                            CornerRadius="3" 
                                            Padding="8,4" 
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding JerseyNumber}" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"
                                                   FontSize="16"/>
                                    </Border>
                                    <TextBlock Text="{Binding FullName}" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="✏️" 
                                            FontSize="12"
                                            Padding="4,2"
                                            Margin="5,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Edit player"
                                            Click="EditButton_Click"/>
                                </StackPanel>

                                <!-- Position & Age -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Position}" 
                                               FontSize="13"
                                               Foreground="#555555"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="•" 
                                               Foreground="#555555"
                                               Margin="0,0,10,0"/>
                                    <TextBlock FontSize="13" Foreground="#555555">
                                        <Run Text="Age:"/>
                                        <Run Text="{Binding Age}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Statistics -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Goals" 
                                                   FontSize="11" 
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Goals}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Assists" 
                                                   FontSize="11" 
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Assists}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Points" 
                                                   FontSize="11" 
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Points}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   Foreground="#4CAF50"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
