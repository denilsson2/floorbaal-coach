<UserControl x:Class="FloorballCoach.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Backup &amp; Återställning" 
                      FontSize="28" 
                      FontWeight="Bold" 
                      Margin="0,0,0,10"/>
            <TextBlock Text="Säkerhetskopiera din data eller återställ från backup" 
                      FontSize="14" 
                      Foreground="#666"/>
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Quick Backup -->
            <Border Grid.Column="0" Background="#4CAF50" CornerRadius="10" Padding="20" Margin="0,0,10,0" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding QuickBackupCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Snabb Backup" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="Spara till standard-mapp" 
                              FontSize="12" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Export -->
            <Border Grid.Column="1" Background="#2196F3" CornerRadius="10" Padding="20" Margin="5,0,5,0" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ExportBackupCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="💾" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Exportera Backup" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="Välj var du vill spara" 
                              FontSize="12" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Import -->
            <Border Grid.Column="2" Background="#FF9800" CornerRadius="10" Padding="20" Margin="10,0,0,0" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ImportBackupCommand}"/>
                </Border.InputBindings>
                <StackPanel>
                    <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Importera Backup" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,5"/>
                    <TextBlock Text="Återställ från fil" 
                              FontSize="12" 
                              Foreground="White" 
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Information Panel -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Status -->
                    <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,20" 
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusMessage}" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  TextWrapping="Wrap"/>
                    </Border>

                    <!-- Information -->
                    <TextBlock Text="ℹ️ Information" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Snabb Backup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock Text="• Sparar automatiskt till: Dokument\FloorballCoach\Backups" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,15"
                              TextWrapping="Wrap"/>

                    <TextBlock Text="Export Backup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock Text="• Välj själv var du vill spara backup-filen"  
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,5"
                              TextWrapping="Wrap"/>
                    <TextBlock Text="• Bra för att spara till USB-minne eller molnlagring" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,15"
                              TextWrapping="Wrap"/>

                    <TextBlock Text="Import Backup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBlock Text="• Återställ data från en backup-fil" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,5"
                              TextWrapping="Wrap"/>
                    <TextBlock Text="• Du kan välja att radera befintlig data eller lägga till" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,15"
                              TextWrapping="Wrap"/>

                    <TextBlock Text="💡 Tips" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,5"/>
                    <TextBlock Text="• Skapa regelbundna backups, speciellt innan större ändringar" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,5"
                              TextWrapping="Wrap"/>
                    <TextBlock Text="• Spara viktiga backups på flera platser (USB, molnlagring)" 
                              FontSize="13" 
                              Foreground="#666" 
                              Margin="0,0,0,5"
                              TextWrapping="Wrap"/>
                    <TextBlock Text="• Backup-filer är i JSON-format och kan öppnas i textredigerare" 
                              FontSize="13" 
                              Foreground="#666" 
                              TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
